url <- paste0("https://", url, "/api/v2/assets.json")
res     <- GET(url,
authenticate(user     = username,
password = password))
stop_for_status(res)
temp = lapply(content(res, as= "parsed")$results, function(res) {
data.frame(name         = res$name,
assetid      = res$uid,
active       = res$deployment__active,
submissions  = res$deployment__submission_count,
owner        = res$owner__username,
date_created = res$date_created,
date_modified = res$date_modified,
URL          = res$url)
})
api =   data.frame(name          = NA,
assetid       = NA,
active        = NA,
submissions   = NA,
owner         = NA,
date_created  = NA,
date_modified = NA,
URL           = NA)[-1,]
for(x in temp) api = rbind(api, x)
return(api)}
### STEP 2: OBTAIN QUESTIONNAIRE INFORMATION
cat("","\n")
cat("Acessando o servidor do Kobo Toolbox","\n")
api <- kobotools_api(url      = kobo_url,
username = kobo_uname,
password = kobo_pwd)
################################################################################
####                     DOWNLOAD PREVIOUS DATA                      ####
################################################################################
deposition          <- GET_LATEST_PUBLISHED_DEPOSITION(deposition_title,
zenodo_token,
zenodo_instance)
previous_data_dir   <- file.path(tempfiles, "previousfiles")
suppressMessages(suppressWarnings({
dir.create(previous_data_dir)
}))
if(!is.null(deposition))
DOWNLOAD_ALL_DEPOSITION_FILES(id = deposition$id,
token = zenodo_token,
instance = zenodo_instance,
path = previous_data_dir)
previous_data_files <- list.files(previous_data_dir)
################################################################################
####                     DOWNLOAD AND PROCESS NEW DATA                      ####
################################################################################
### --------------- STEP 1: FETCH QUESTIONNAIRE INFORMATION ---------------- ###
questionnaire_information_path <- file.path("SUPORTE",
"support_tables",
"questionnaire_information.xlsx")
questionnaires  <- read_excel(questionnaire_information_path, sheet = "questionnaires")
dat_information <- read_excel(questionnaire_information_path, sheet = "data")
variables       <- read_excel(questionnaire_information_path, sheet = "variables")
### ----------------- STEP 2: DOWNLOAD QUESTIONNAIRE DATA ------------------ ###
# 1. FUNCTION TO DOWNLOAD KOBOCOLLECT DATA
kobodownload <- function(questionnaire_name) {
assetid  <- api$asset[which(api$name == questionnaire_name)]
asseturl <- paste0("https://", kobo_url, "/api/v2/assets/", assetid, "/data/")
output   <- list()
tryCatch(
{
repeat {
res           <- httr::GET(asseturl, authenticate(kobo_uname, kobo_pwd))
stop_for_status(res)
parsed        <- content(res, as = "parsed")
output        <- c(output, parsed$results)
if (is.null(parsed$"next")) break
asseturl <- parsed$"next"
}
cat(paste0("      Descarregado questionário '", questionnaires$questionnaire_name[i], "'"),"\n")
}, error = function(e){
if(status_code(res) == 404)
cat(paste0("      (!)  Questionário '", questionnaire_name, "' não existe"),"\n")
output = list()
}
)
return(output)}
# 2. DOWNLOAD ALL QUESTIONNAIRE DATA AND EXCLUDE PREVIOUS INSTANCES, IF ANY
cat("\nDescarregando novos questionários","\n")
for(i in 1:nrow(questionnaires)){
# Download previous data
newdat <- kobodownload(questionnaires$questionnaire_name[i])
if(paste0(questionnaires$objectname[i], ".rds") %in% previous_data_files){
# Remove instances that have been previously backed up
olddat <- readRDS(file.path(previous_data_dir,
paste0(questionnaires$objectname[i], ".rds")))
olddat_uuid <- unlist(lapply(olddat, function(x) x$"_uuid"))
newdat_uuid <- unlist(lapply(newdat, function(x) x$"_uuid"))
newdat <- newdat[!newdat_uuid %in% olddat_uuid]
}
assign(questionnaires$objectname[i], newdat)
}
### ------------------ STEP 3: PROCESS QUESTIONNAIRE DATA ------------------ ###
cat("\nProcessando dados","\n")
for(i in 1:nrow(dat_information)){
### 1. FETCH PARENT DATA
parent        <- get(dat_information$parent[i])
### 2. FETCH DATA SPECIFICATIONS
location      <- dat_information$location[i]
nestedname    <- dat_information$nestedname[i]
dat_name      <- dat_information$dat[i]
version       <- dat_information$version[i]
not_version   <- dat_information$not_version[i]
questionnaire_name    <- questionnaires$questionnaire_name[
which(questionnaires$objectname == dat_information$parent[i])]
### 3. STATUS MESSAGE
cat(paste0("      Processando dados de '", dat_name, "'"),"\n")
### 4. HANDLING VERSIONS, if relevant
if(!is.na(version) | !is.na(not_version)) {
# 4.1 Fetch all version uids
assetid  <- api$asset[which(api$name == questionnaire_name)]
asseturl <- paste0("https://", kobo_url, "/api/v2/assets/", assetid, "/versions/")
res           <- httr::GET(asseturl, authenticate(kobo_uname, kobo_pwd))
stop_for_status(res)
uids          <- unlist(lapply(content(res, as = "parsed")$results,
function(x) x$uid))
# 4.2 Select only uids present on data
uids          <- uids[uids %in% unlist(lapply(parent, function(x) x$"__version__"))]
version.df    <- data.frame(version = "a", uid = "b")[-1,]
# 4.3 Obtain version name of each uid
for(uid in uids) {
asseturl <- paste0("https://", kobo_url, "/api/v2/assets/", assetid, "/versions/",uid)
res           <- httr::GET(asseturl, authenticate(kobo_uname, kobo_pwd))
stop_for_status(res)
version_name  <- content(res, as = "parsed")$content$settings$version
if(is.null(version_name)) version_name = as.character(NA)
version.df = rbind(version.df, data.frame(version = version_name, uid = uid))
}
# 4.4 Select only instances from specific version, IF RELEVANT
if(!is.na(version)) {
if(version %in% version.df$version){
version = version.df$uid[version.df$version == version]
}
}
if(!is.na(not_version)) {
if(not_version %in% version.df$version){
not_version = version.df$uid[version.df$version == not_version]
}
}
allversions <- unlist(lapply(parent,function(instance) instance$"__version__"))
if(!is.null(not_version)) if(!is.na(not_version))
parent      <- parent[!allversions %in% not_version]
if(!is.null(version)) if(!is.na(version))
parent      <- parent[allversions %in% version]
}
### 5. PROCESS DATA
if(!is.null(parent)){
# If nested, create a separate list, fetching uuid and id from parent
if(location == "nested"){
nested <- lapply(parent, function(instance) {
if(nestedname %in% names(instance)){
output       = instance[which(names(instance) == nestedname)][[1]]
for(i in 1:length(output)) output[[i]]$"_uuid" = instance$"_uuid"
for(i in 1:length(output)) output[[i]]$"_id" = instance$"_id"
return(output)}
})
nested <- unlist(nested, recursive = FALSE) # Flatten list
}
# Select data from nested or parent data based on 'location' (i.e., nested or parent)
dat <- get(location)
if(length(dat) > 0){
# Nested list to data frame via "jsonlite" package
dat <- fromJSON(toJSON(dat,
auto_unbox = TRUE,
pretty = TRUE,
encoding = "UTF-8"),
flatten = TRUE)
# Remove group names from variables
pos           = unlist(lapply(colnames(dat),  function(nam)  max(gregexpr("/",nam)[[1]])))
colnames(dat) = substr(colnames(dat),  pos+1, nchar(colnames(dat)))
# Create list of all variable names (including uuid and id)
varnames      = variables$variablename[which(variables$dat == dat_name)]
varnames      = c("_uuid","_id", varnames)
# Add questionnaire variables not in the data frame
for(varname in varnames){
dat$temp = NA
colnames(dat)[which(colnames(dat) == "temp")] = varname
}
# Select only relevant variables
dat           = dat[,varnames]
# Add date_time tag
dat$data_descarga = datetime_lab
# Handle uuid and id
colnames(dat)[colnames(dat) == "_uuid"] = "uuid"
colnames(dat)[colnames(dat) == "_id"]   = "id"
dat$uuid  = as.character(dat$uuid)
dat$id    = as.character(dat$id)
# Standardize class of data frame columns
for(j in which(variables$dat == dat_name &
variables$variablename %in% colnames(dat))){
varname       = variables$variablename[j]
as.class      = get(paste("as", variables$class[j], sep = "."))
dat[,varname] = as.class(dat[,varname])
}
# Character replacement
dash  = c("-")
dot   = c(".")
space = c(" ")
linebreak = c("\n", "\r")
for(j in which(variables$dat == dat_name &
variables$character_replacement_needed)){
varname       = variables$variablename[j]
pattern       = strsplit(variables$pattern[j],";")[[1]]
replacement   = strsplit(variables$replacement[j],";")[[1]]
if(length(replacement) == 1)
replacement = rep(replacement, length(pattern))
if(length(pattern) == length(replacement))
for(h in 1:length(pattern))
for(pat in get(pattern[h]))
dat[,varname] = gsub(pat,
get(replacement[h]),
dat[,varname],
fixed = TRUE)
}
# Assign database name (dat_name) to processed database (dat)
assign(dat_name, dat)
} else {assign(dat_name, NULL)}
} else {assign(dat_name, NULL)}
}
### ------------------- STEP 4: REMOVE TEMPORARY OBJECTS ------------------- ###
suppressWarnings(rm(dash, dat_name,dot,h,j,i,linebreak,
location,nestedname,not_version,version,
varname, varnames,as.class, allversions,
deletetempdirs, deletetempfiles, dat,
credentials, parent, nested, pat, pattern,
questionnaire_information_path, replacement,
space, newdat, deposition, pos, newdat, olddat,
newdat_uuid, olddat_uuid, questionnaire_information_path,
uid, uids, version_name, version.df)
)
################################################################################
####                      PROCESS ATTACHMENTS                     ####
################################################################################
### ----- STEP 1: CREATE DATA FRAME WITH VARIABLE NAMES OF ATTACHMENTS ----- ###
suppressMessages(suppressWarnings(rm(attachments)))
for(i in 1:nrow(questionnaires)){
questionnaire_name = questionnaires$questionnaire_name[i]
parentname         = questionnaires$objectname[i]
if(questionnaire_name %in% api$name) {
assetid  <- api$asset[which(api$name == questionnaire_name)]
asseturl <- paste0("https://", kobo_url, "/api/v2/assets/", assetid, "/")
res           <- httr::GET(asseturl, authenticate(kobo_uname, kobo_pwd))
stop_for_status(res)
parsed        <- content(res, as = "parsed")$content$survey
questiontypes <- unlist(lapply(parsed, function(x)
if(!is.null(x$type)) x$type else NA))
questiontypes_with_attachments <- c("image",  "audio",  "video",  "file",  "signature")
questionnames <- unlist(lapply(parsed, function(x)
if(!is.null(x$name)) x$name else NA))
questionnames <- questionnames[which(questiontypes %in%
questiontypes_with_attachments)]
if(length(questionnames) > 0){
for(j in 1:length(questionnames)){
varname       = questionnames[j]
datname       = dat_information$dat[              # Fetch database names within parent
which(dat_information$parent == parentname)    ]
datname    = variables$dat[which(                 # Select database that contains variable name
variables$dat %in% datname  &
variables$variablename == varname    )]
if(length(datname) > 0) {
temp = data.frame(parent       = parentname,
dat          = datname,
variablename = varname)
if(!exists("attachments")) attachments = temp else attachments = rbind(attachments, temp)
}
}
}
if("is_attachment" %in% colnames(variables)) {
datname       = dat_information$dat[              # Fetch database names within parent
which(dat_information$parent == parentname)    ]
positions     = which(variables$dat %in% datname &
variables$is_attachment)
if(length(positions) > 0) {
temp        = variables[positions,]
temp$parent = parentname
temp        = temp[,c("parent","dat","variablename")]
if(!exists("attachments"))
attachments = temp else
attachments = rbind(
attachments,
temp[!paste(temp$dat, temp$variablename) %in%
paste(attachments$dat, attachments$variablename)
, ])
}
}
}
}
### --------- STEP 2: CREATE VARIABLE FOR STORING ATTACHMENT LINKS --------- ###
for(i in 1:nrow(attachments)){
temp <- get(attachments$dat[i])
if(!is.null(temp)){
varname = attachments$variablename[i]
if(varname %in% names(temp)){
link_column_name = paste0(varname, "_link")
if(!link_column_name %in% colnames(temp)){
firsthalf   = colnames(temp)[1:which(colnames(temp) == varname)]
secondhalf  = colnames(temp)[(which(colnames(temp) == varname) + 1) : ncol(temp)]
temp <- data.frame(temp[,firsthalf],
link = as.character(NA),
temp[,secondhalf])
colnames(temp) <- c(firsthalf, link_column_name, secondhalf)
assign(attachments$dat[i], temp)
}
}
}
}
### --------------- STEP 3: CREATE DATA FRAME OF ATTACHMENTS --------------- ###
quest_with_attch <- c()
for(parentname in questionnaires$objectname){
if(exists(parentname)){
parent = get(parentname)
if(length(parent) == 0)    quest_with_attch <- c(quest_with_attch, 0)
if(length(parent) > 0) {
# Obtain attachment information
attch_info = lapply(parent, function(x){
x = x$'_attachments'
if(length(x) == 0 | is.null(x)) {output = NULL} else {
temp = lapply(x, function(y)
data.frame(url = y$download_large_url,
filename = substr(y$filename,max(gregexpr("/",y$filename)[[1]])+1,nchar(y$filename)),
mimetype = y$mimetype
))
for(i in 1:length(temp)) if(i==1) output = temp[[i]] else output = rbind(temp[[i]],output)
}
return(output)})
# Extract position of instances that have attachements?
positions <- which(unlist(lapply(attch_info, function(x) !is.null(x))))
# If attachments exist, 1 else 0
if(length(positions) > 0) {
quest_with_attch <- c(quest_with_attch, 1)
} else {
quest_with_attch <- c(quest_with_attch, 0)
}
# If attachments exist, restructure attachment info database
if(length(positions) > 0){
attch_info = attch_info[positions]
# Create data frame with information on all attachments
for(i in 1:length(attch_info)){
temp            = attch_info[[i]]
temp$filepath   = file.path(tempfiles,temp$filename)
temp$parentname = parentname
if(i == 1 & sum(quest_with_attch) == 1) {
attch_list = temp
} else {
attch_list = rbind(attch_list, temp)
}
}
}
}
}
}
### -------------------- STEP 5: UPLOAD NEW ATTACHMENTS -------------------- ###
if(sum(quest_with_attch) > 0){
cat("\nProcessando novos anexos","\n")
} else {
cat("\nNão existem novos anexos","\n")
}
if(sum(quest_with_attch) > 0){
# 1. CREATE NEW VERSION OR DEPOSITION
attch_deposition <- CREATE_NEW_VERSION_OR_DEPOSITION(title       = paste(deposition_title, "ATTACHMENTS"),
description = deposition_description,
creators    = deposition_creators,
token       = zenodo_token,
instance    = zenodo_instance,
restricted  = FALSE)
# 2. DELETE FILES FROM PREVIOUS VERSIONS TO PREVENT LARGE REP. SIZE
# (links to files of previous versions still exist and are active)
for(x in attch_deposition$files)
DELETE(x$links$self,
add_headers(Authorization = paste("Bearer", zenodo_token)))
# 3. FOR EVERY ATTACHMENT: DOWNLOAD, UPLOAD TO ZENODO, AND ALLOCATE LINK
cat(paste("      Descarregando",nrow(attch_list),"anexos novos. O processo pode demorar um pouco"),"\n")
for(i in 1:nrow(attch_list)){
# 3.1 Download local copy
cat(paste("      Descarregando anexo",i,"de",nrow(attch_list)),"\n")
res <- GET(
attch_list$url[i],
authenticate(kobo_uname, kobo_pwd),
write_disk(attch_list$filepath[i], overwrite = TRUE)
)
stop_for_status(res)
# 3.2 Upload to attachment deposition
filename          = attch_list$filename[i]
attachment_link   =
UPLOAD_TO_DEPOSITION(filepath = attch_list$filepath[i],
id       = attch_deposition$id,
name     = attch_list$filename[i],
token    = zenodo_token,
instance = zenodo_instance)
cat(paste("      Anexo", attch_list$filename[i], "carregado no Zenodo\n"))
# 3.3 Find containing variables and allocate link
parentname = attch_list$parentname[i]
att        = attachments[which(attachments$parent == parentname),]
for(j in 1:nrow(att)){
datname  = att$dat[j]
dat      = get(datname)
if(!is.null(dat)){
varname = att$variablename[j]
var     = dat[,which(colnames(dat) == varname)]
row_position <- which(!is.na(var) & var == filename)
col_position <- which(colnames(dat) == paste0(varname, "_link"))
if(length(c(col_position, row_position)) > 0){
dat[row_position, col_position] = attachment_link
assign(datname, dat)
}
}
}
}
}
suppressWarnings(rm(att, attch_info, attch_link, attch_list, attachments, dat,
parent, res, temp, col_position, datname, filename, firsthalf,
i, j, link_column_name, parentname, positions, row_position,
secondhalf, var, varname, x, parsed, questionnames,
questiontypes, questiontypes_with_attachments))
################################################################################
####                   UPLOAD TO ZENODO AND SAVE NEW DATA                   ####
################################################################################
#### --------------------- 1. CREATE COPY OF RAW DATA --------------------- ####
for(dat in dat_information$dat)  assign(paste0(dat, "_RAW"), get(dat))
#### -------------------------- 2. CLEAN NEW DATA ------------------------- ####
# Clean data
source(file.path("SUPORTE", "script", "00_clean_new_data.R"), local = TRUE)
alldat <- list()
for(i in 1:length(dat_information$dat)){
temp = list(get(dat_information$dat[i]))
names(temp) = dat_information$dat[i]
alldat        <- c(alldat, temp)
}
for(i in 1:length(dat_information$dat)){
datname = paste0(dat_information$dat[i], "_RAW")
if(!is.null(get(datname))) {
temp = list(get(datname))
names(temp) = datname
alldat        <- c(alldat, temp)
}
}
#### ---------------- 3. CALCULATE NUMBER OF NEW INSTANCES ---------------- ####
total_instances <- sum(
unlist(lapply(questionnaires$objectname,
function(x) if(is.null(get(x)))
0 else length(get(x))
)))
#### -------------------- 4. IF NO DATA, RETURN MESSAGE ------------------- ####
if(total_instances == 0){
cat("Não existem dados novos\n")
}
#### ---------------- 5. IF DATA EXISTS, UPLOAD AND PUBLISH --------------- ####
if(total_instances > 0){
### 1. VECTORS WITH NAMES OF DATABASES
all_quest_names   <- questionnaires$objectname
all_dat_names     <- dat_information$dat
all_dat_names_RAW <- paste0(all_dat_names, "_RAW")
### 2. UPLOADING NEW COLLATED DATABASE (OLD AND NEW DATA)
# 2.1. Create new deposition version for collated data
cat("\nCriando nova versão ou repositório de dados\n")
deposition <- CREATE_NEW_VERSION_OR_DEPOSITION(title       = paste(deposition_title),
description = deposition_description,
creators    = deposition_creators,
token       = zenodo_token,
instance    = zenodo_instance)
# 2.2 Collate new data with previous data and upload to Zenodo
cat("\nCarregando base de dados completa em Zenodo\n")
for(newdatname in c(all_quest_names, all_dat_names, all_dat_names_RAW)){
newdat = get(newdatname)
if(!is.null(newdat)) if(!length(newdat) == 0) {
# Check whether previous data exists, and if so collate it
if(paste0(newdatname, ".rds") %in% previous_data_files){
olddat <- readRDS(file.path(previous_data_dir,
paste0(newdatname, ".rds")))
if(newdatname %in% all_quest_names) {
alldat = c(olddat, newdat)
} else {
alldat = bind_rows(olddat, newdat)
}
} else {alldat = newdat}
# Upload collated version to Zenodo, deleting the previous one
path = file.path(tempfiles,  paste0(newdatname, ".rds"))
saveRDS(alldat, path)
DELETE_FILE(filename = paste0(newdatname, ".rds"),
id       = deposition$id,
token    = zenodo_token,
instance = zenodo_instance)
UPLOAD_TO_DEPOSITION(filepath = path,
name     = paste0(newdatname, ".rds"),
id       = deposition$id,
token    = zenodo_token,
instance = zenodo_instance)
cat(paste0("      Dados de ",newdatname, " foram carregados em Zenodo\n"))
} else {cat(paste0("      Não existem novos dados de ",newdatname, "\n"))}
}
### 3. PUBLISH ATTACHMENT DEPOSITION
if(sum(quest_with_attch) > 0){
cat("\nPublicando repositório de anexos\n")
attch_deposition <- PUBLISH_DEPOSITION(id       = attch_deposition$id,
token    = zenodo_token,
instance = zenodo_instance)
}
### 4. PUBLISH COLLATED DATA DEPOSITION
cat("\nPublicando repositório de dados\n")
deposition <- PUBLISH_DEPOSITION(id       = deposition$id,
token    = zenodo_token,
instance = zenodo_instance)
}
deletetempfiles <- list.files(file.path(tempfiles),full.names = TRUE)
suppressMessages(suppressWarnings(invisible(file.remove(deletetempfiles))))
cat("","\n")
cat("","\n")
cat("","\n")
